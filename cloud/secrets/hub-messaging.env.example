# hub-messaging.env.example
# ---------------------------------------------------------------------------
# Required environment variables for outbound homeward owner-notify and relay
# email delivery on the hub.
#
# Copy this file to ~/.config/wintermute/secrets/messaging.env on the hub,
# fill in real values, and chmod 0600.  Do NOT commit the filled-in copy —
# use constellation's sops path instead (see hub-messaging.md).
#
# These vars are consumed by:
#   • homeward-reportd (delivery.rs)  — HOMEWARD_RELAY_* + HOMEWARD_DATA_DIR
#   • hub-messaging-subscriber.service — all of the below
# ---------------------------------------------------------------------------

# ---------------------------------------------------------------------------
# Relay endpoint (HTTP relay for brokered contact-token sends)
# ---------------------------------------------------------------------------

# HTTPS URL of the relay service that accepts contact-token notify payloads.
# Required for live sends; if unset, homeward-reportd degrades to dry-run.
HOMEWARD_RELAY_ENDPOINT=

# Optional: per-request timeout in seconds for relay POSTs (default: 10)
HOMEWARD_RELAY_TIMEOUT_SECS=

# Set to 1 only for local testing to allow plain http:// relay URLs.
# Must be empty or unset in production.
HOMEWARD_RELAY_ALLOW_HTTP=

# ---------------------------------------------------------------------------
# SMTP credentials (used by the relay to authenticate upstream if it needs
# them, OR by a future direct-SMTP delivery path)
# ---------------------------------------------------------------------------

# SMTP server hostname (e.g. smtp.mailgun.org, smtp.sendgrid.net)
HOMEWARD_SMTP_HOST=

# SMTP port — 587 for STARTTLS (recommended), 465 for TLS, 25 for plain
HOMEWARD_SMTP_PORT=587

# SMTP username / sender address
HOMEWARD_SMTP_USER=

# SMTP password or app-specific password / API key
HOMEWARD_SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Relay provider API credentials (Mailgun, SendGrid, etc.)
# ---------------------------------------------------------------------------

# API key for the relay email provider
HOMEWARD_RELAY_API_KEY=

# Sending domain registered with the relay provider (e.g. mg.yourdomain.com)
HOMEWARD_RELAY_DOMAIN=

# ---------------------------------------------------------------------------
# Sender identity
# ---------------------------------------------------------------------------

# "From" address that owners see on notification emails
HOMEWARD_NOTIFY_FROM=

# Optional reply-to address (leave empty to omit the header)
HOMEWARD_NOTIFY_REPLY_TO=

# ---------------------------------------------------------------------------
# Data paths (usually left at defaults; override only if needed)
# ---------------------------------------------------------------------------

# Root data directory for homeward state files
# Default: $HOME/.local/share/homeward
HOMEWARD_DATA_DIR=

# Path to the ingest SQLite database
# Default: $HOMEWARD_DATA_DIR/homeward-ingest.db
HOMEWARD_INGEST_DB=

# ---------------------------------------------------------------------------
# NATS bus credentials (also loaded from nats.env; listed here for reference)
# ---------------------------------------------------------------------------

# NATS server URL (e.g. nats://hub.internal:4222)
# NATS_URL=          # set in nats.env, not here

# NATS credentials file path
# NATS_CREDS=        # set in nats.env, not here
