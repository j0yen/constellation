#!/usr/bin/env bash
# constellation-secrets — bootstrap + service-secret layer for the wintermute fleet.
#
# SIGPIPE safety: trap SIGPIPE first so `constellation-secrets get … | head`
# never aborts with a broken-pipe error (AC9 / self_sigpipe_panic_toolkit).
trap '' PIPE

set -uo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
SECRETS_ROOT="${CONSTELLATION_SECRETS_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/secrets}"
AGE_KEYS_FILE="${SOPS_AGE_KEY_FILE:-${HOME}/.config/sops/age/keys.txt}"
CANARY_FILE="${SECRETS_ROOT}/canary.yaml"
SOPS_CONFIG="${SECRETS_ROOT}/../.sops.yaml"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"

usage() {
    cat <<'EOF'
constellation-secrets — bootstrap and decrypt the constellation secret store.

USAGE:
  constellation-secrets bootstrap [--key-file <path>]
      Install the host root age key to ~/.config/sops/age/keys.txt (0600),
      verify it decrypts the committed canary, refuse + exit non-zero on
      mis-delivered key. Idempotent: no-op if the exact key is already present.

  constellation-secrets get [--check] [--out <path>] <name>
      Decrypt a named secret to stdout (default) or a 0600 path under
      /run/user/$UID.  With --check, exit non-zero when the secret is absent
      or cannot be decrypted (fail-fast before consumers start).

  constellation-secrets audit [--role <role>]
      Assert the repo contains no plaintext secret; assert every declared secret
      for the role is decryptable or report missing. Exit non-zero on any leak
      or undeclared reference.

  constellation-secrets list [--role <role>]
      List available secrets for the host role.

  constellation-secrets help
      Show this message.

ENVIRONMENT:
  CONSTELLATION_SECRETS_ROOT   Override secrets tree location (default: ../secrets/)
  SOPS_AGE_KEY_FILE            Override age key file path
  CONSTELLATION_ROLE           host role: laptop | cloud | shared (default: auto-detect)

DELIVERY CHANNELS (bootstrap):
  Recommended — manual paste over SSH:
    ssh user@newhost 'mkdir -p ~/.config/sops/age && cat > /tmp/age.key'
    # paste the private age key, Ctrl-D
    ssh user@newhost 'constellation-secrets bootstrap --key-file /tmp/age.key && shred -u /tmp/age.key'

  Alternative — USB stick (air-gapped first boot):
    Copy the age private key to a USB stick, mount it on the fresh host, then:
    constellation-secrets bootstrap --key-file /mnt/usb/age-host.key
    # script installs + verifies, then you eject + physically destroy the copy.

  Once mesh is up — tunnel option:
    # Route the key through the already-running Tailscale tunnel from a trusted node:
    tailscale ssh user@newhost 'mkdir -p ~/.config/sops/age'
    tailscale ssh user@newhost "cat > /tmp/age.key" < /path/to/age-host.key
    tailscale ssh user@newhost 'constellation-secrets bootstrap --key-file /tmp/age.key && shred -u /tmp/age.key'

NEVER: email, paste into git, or leave in shell history (~/.bash_history).
       The --key-file argument should point to a tmpfs path or USB mount, not
       $HOME or any world-readable location.
EOF
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
log() { printf '[constellation-secrets] %s\n' "$*" >&2; }
die() { log "ERROR: $*"; exit 1; }

require_cmd() {
    command -v "$1" >/dev/null 2>&1 || die "Required command not found: $1. Install it first."
}

detect_role() {
    if [[ -n "${CONSTELLATION_ROLE:-}" ]]; then
        printf '%s' "$CONSTELLATION_ROLE"
        return
    fi
    # Heuristic: cloud nodes have no display, laptop nodes have one.
    # Prefer explicit env override in production.
    if [[ -z "${DISPLAY:-}" && -z "${WAYLAND_DISPLAY:-}" ]]; then
        printf 'cloud'
    else
        printf 'laptop'
    fi
}

secret_file() {
    local name="$1"
    local role
    role=$(detect_role)
    # Search: role-specific first, then shared
    for dir in "${SECRETS_ROOT}/${role}" "${SECRETS_ROOT}/shared"; do
        local f="${dir}/${name}.yaml"
        if [[ -f "$f" ]]; then
            printf '%s' "$f"
            return 0
        fi
    done
    return 1
}

safe_runtime_path() {
    local name="$1"
    # Sanitise name to filesystem-safe slug
    local slug
    slug=$(printf '%s' "$name" | tr -cs 'a-zA-Z0-9_.-' '_')
    local dir="${RUNTIME_DIR}/constellation-secrets"
    mkdir -p "$dir"
    chmod 700 "$dir"
    printf '%s/%s' "$dir" "$slug"
}

# ---------------------------------------------------------------------------
# Subcommand: bootstrap
# ---------------------------------------------------------------------------
cmd_bootstrap() {
    local key_file=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --key-file) key_file="$2"; shift 2 ;;
            *) die "Unknown bootstrap option: $1" ;;
        esac
    done

    require_cmd age
    require_cmd sops

    # Read the key from key-file or stdin
    local key_data
    if [[ -n "$key_file" ]]; then
        [[ -f "$key_file" ]] || die "Key file not found: $key_file"
        key_data=$(cat "$key_file")
    else
        log "Reading age private key from stdin (paste key, then Ctrl-D):"
        key_data=$(cat)
    fi

    [[ -n "$key_data" ]] || die "Empty key data; aborting."

    # Validate it looks like an age private key
    printf '%s\n' "$key_data" | grep -q '^AGE-SECRET-KEY-' \
        || die "Key does not appear to be a valid age private key (expected AGE-SECRET-KEY-… header)."

    # Extract the public key for idempotency check
    local pub_key
    pub_key=$(printf '%s\n' "$key_data" | age-keygen -y 2>/dev/null) \
        || die "Failed to derive public key; key may be malformed."

    # Idempotency: if the exact public key is already in keys.txt, no-op
    mkdir -p "$(dirname "$AGE_KEYS_FILE")"
    if [[ -f "$AGE_KEYS_FILE" ]] && grep -qF "$pub_key" "$AGE_KEYS_FILE" 2>/dev/null; then
        log "Key (pub: ${pub_key}) is already present in ${AGE_KEYS_FILE} — no-op."
        exit 0
    fi

    # Canary verification BEFORE installing the key (fail loud on mis-delivery)
    if [[ -f "$CANARY_FILE" ]]; then
        log "Verifying key against canary at ${CANARY_FILE} ..."
        local canary_tmp
        canary_tmp=$(mktemp)
        # Write key to tmpfs for sops to use
        local key_tmp
        key_tmp=$(mktemp)
        chmod 600 "$key_tmp"
        printf '%s\n' "$key_data" > "$key_tmp"

        if ! SOPS_AGE_KEY_FILE="$key_tmp" sops --decrypt "$CANARY_FILE" > "$canary_tmp" 2>/dev/null; then
            shred -u "$key_tmp" "$canary_tmp" 2>/dev/null || rm -f "$key_tmp" "$canary_tmp"
            die "Canary verification FAILED — mis-delivered key refuses to install. Check your key source."
        fi
        shred -u "$key_tmp" "$canary_tmp" 2>/dev/null || rm -f "$key_tmp" "$canary_tmp"
        log "Canary verified OK."
    else
        log "WARNING: No canary file found at ${CANARY_FILE}; skipping canary check."
        log "         Run 'constellation-secrets audit' after bootstrap to validate the store."
    fi

    # Install the key (append, preserve existing keys for key rotation)
    touch "$AGE_KEYS_FILE"
    chmod 600 "$AGE_KEYS_FILE"
    printf '\n# constellation bootstrap %s\n%s\n' "$(date -u +%Y-%m-%dT%H:%M:%SZ)" "$key_data" >> "$AGE_KEYS_FILE"
    log "Root age key installed to ${AGE_KEYS_FILE} (mode 0600)."
    log "Bootstrap complete. Public key: ${pub_key}"
}

# ---------------------------------------------------------------------------
# Subcommand: get
# ---------------------------------------------------------------------------
cmd_get() {
    local check_mode=false
    local out_path=""
    local secret_name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --check) check_mode=true; shift ;;
            --out)   out_path="$2"; shift 2 ;;
            -*)      die "Unknown get option: $1" ;;
            *)       secret_name="$1"; shift ;;
        esac
    done

    [[ -n "$secret_name" ]] || die "Usage: constellation-secrets get [--check] [--out <path>] <name>"

    require_cmd sops

    local sf
    if ! sf=$(secret_file "$secret_name"); then
        if $check_mode; then
            log "MISSING: secret '${secret_name}' not found for role $(detect_role)."
            exit 1
        fi
        die "Secret '${secret_name}' not found in store (role: $(detect_role))."
    fi

    # Decrypt
    local plaintext
    if ! plaintext=$(sops --decrypt --extract '["value"]' "$sf" 2>/dev/null); then
        if $check_mode; then
            log "UNDECRYPTABLE: secret '${secret_name}' exists but cannot be decrypted."
            exit 1
        fi
        die "Failed to decrypt secret '${secret_name}'. Is the host root key installed? (Run: constellation-secrets bootstrap)"
    fi

    if [[ -n "$out_path" ]]; then
        # Validate output path: must be under /run/user/$UID or a supplied safe path
        local uid_run="/run/user/$(id -u)"
        # Also allow RUNTIME_DIR which may differ
        if [[ "$out_path" != "${uid_run}"* && "$out_path" != "${RUNTIME_DIR}"* ]]; then
            die "Output path '${out_path}' is outside the permitted runtime dir (${uid_run}). Plaintext never written to repo or dotfiles."
        fi
        local dir
        dir=$(dirname "$out_path")
        mkdir -p "$dir"
        chmod 700 "$dir"
        # Write atomically via temp file
        local tmp
        tmp=$(mktemp "${out_path}.XXXXXX")
        chmod 600 "$tmp"
        printf '%s\n' "$plaintext" > "$tmp"
        mv "$tmp" "$out_path"
        chmod 600 "$out_path"
        log "Secret '${secret_name}' written to ${out_path} (mode 0600)."
    else
        # stdout — SIGPIPE is already trapped; just print
        printf '%s\n' "$plaintext"
    fi
}

# ---------------------------------------------------------------------------
# Subcommand: audit
# ---------------------------------------------------------------------------
cmd_audit() {
    local role=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            *) die "Unknown audit option: $1" ;;
        esac
    done

    [[ -n "$role" ]] || role=$(detect_role)
    require_cmd sops
    require_cmd grep

    local exit_code=0

    # 1. Plaintext leak scan — grep for secret-shaped patterns in the secrets tree
    log "--- Plaintext leak scan (${SECRETS_ROOT}) ---"
    local leak_patterns=(
        'AGE-SECRET-KEY-'
        'tskey-[a-zA-Z0-9_-]{20,}'
        'sk-ant-[a-zA-Z0-9_-]{20,}'
        'NATS_'
    )
    for pattern in "${leak_patterns[@]}"; do
        if grep -r --include='*.yaml' --include='*.yml' --include='*.txt' \
               --include='*.env' --include='*.json' \
               -l -E "$pattern" "$SECRETS_ROOT" 2>/dev/null | grep -v '\.bak$'; then
            log "PLAINTEXT LEAK DETECTED: pattern '${pattern}' found in plaintext in the above files."
            exit_code=1
        fi
    done

    # Also scan the entire constellation tree for accidental commit of private keys
    local tree_root
    tree_root=$(cd "${SECRETS_ROOT}/.." && pwd)
    for pattern in 'AGE-SECRET-KEY-' 'tskey-[a-zA-Z0-9_-]{20,}' 'sk-ant-[a-zA-Z0-9_-]{20,}'; do
        if grep -r --include='*.yaml' --include='*.yml' --include='*.sh' \
               --include='*.md' --include='*.txt' \
               -l -E "$pattern" "$tree_root" 2>/dev/null \
               | grep -v "${SECRETS_ROOT}"; then
            log "PLAINTEXT LEAK DETECTED in repo tree: pattern '${pattern}' found above."
            exit_code=1
        fi
    done

    if [[ $exit_code -eq 0 ]]; then
        log "Plaintext leak scan: CLEAN — no plaintext secrets found."
    fi

    # 2. Decryptability check for every declared secret in the role
    log "--- Decryptability check (role: ${role}) ---"
    local declared_secrets=("nats.creds" "tailscale_authkey" "WM_ANTHROPIC_API_KEY")
    local any_missing=false

    for name in "${declared_secrets[@]}"; do
        local sf
        if sf=$(secret_file "$name" 2>/dev/null); then
            if sops --decrypt --extract '["value"]' "$sf" >/dev/null 2>&1; then
                log "  OK        ${name} (${sf})"
            else
                log "  DECRYPT-FAIL  ${name} — file exists but key cannot decrypt it."
                exit_code=1
            fi
        else
            log "  MISSING   ${name} — not present for role ${role}."
            any_missing=true
            # Missing secrets are reported but not a hard failure unless referenced
        fi
    done

    if $any_missing; then
        log "NOTE: Some secrets are missing. Add them with sops before fleet provision."
    fi

    if [[ $exit_code -ne 0 ]]; then
        log "AUDIT FAILED — see above."
        exit $exit_code
    fi
    log "Audit PASSED for role '${role}'."
}

# ---------------------------------------------------------------------------
# Subcommand: list
# ---------------------------------------------------------------------------
cmd_list() {
    local role=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --role) role="$2"; shift 2 ;;
            *) die "Unknown list option: $1" ;;
        esac
    done

    [[ -n "$role" ]] || role=$(detect_role)

    for dir in "${SECRETS_ROOT}/${role}" "${SECRETS_ROOT}/shared"; do
        if [[ -d "$dir" ]]; then
            find "$dir" -name '*.yaml' -printf '%f\n' 2>/dev/null \
                | sed 's/\.yaml$//' \
                | sort
        fi
    done
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
[[ $# -gt 0 ]] || { usage; exit 0; }

subcommand="$1"
shift

case "$subcommand" in
    bootstrap) cmd_bootstrap "$@" ;;
    get)       cmd_get       "$@" ;;
    audit)     cmd_audit     "$@" ;;
    list)      cmd_list      "$@" ;;
    help) usage ;;
    --help|-h) usage ;;
    *) die "Unknown subcommand: ${subcommand}. Run 'constellation-secrets help'." ;;
esac
