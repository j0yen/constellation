# i3status config — constellation appearance layer
# Managed by chezmoi. DO NOT EDIT ~/.config/i3status/config directly.
# Source: constellation/chezmoi/dot_config/i3status/config.tmpl
#
# HOST-INVARIANT: all blocks except battery (gated on .has_battery).
# Non-gated sections render byte-identical across all nodes.

general {
        colors = true
        color_good     = "#28FE14"
        color_degraded = "#c7c400"
        color_bad      = "#c91b00"
        interval = 5
}

# ---------------------------------------------------------------------------
# Order — battery block present only on nodes with .has_battery = true
# ---------------------------------------------------------------------------
order += "wireless _first_"
order += "ethernet _first_"
{{ if .has_battery -}}
order += "battery all"
{{ end -}}
order += "cpu_usage"
order += "memory"
order += "disk /"
order += "load"
order += "tztime local"

# ---------------------------------------------------------------------------
# Block definitions — byte-identical across nodes
# ---------------------------------------------------------------------------
wireless _first_ {
        format_up   = "W: (%quality at %essid) %ip"
        format_down = "W: down"
}

ethernet _first_ {
        format_up   = "E: %ip (%speed)"
        format_down = "E: down"
}

{{ if .has_battery -}}
# Battery block — only on nodes where has_battery = true (laptop)
battery all {
        format = "%status %percentage %remaining"
        format_down = "No battery"
        status_chr = "CHR"
        status_bat = "BAT"
        status_unk = "UNK"
        status_full = "FULL"
        path = "/sys/class/power_supply/BAT%d/uevent"
        low_threshold = 15
}
{{ end -}}

cpu_usage {
        format = "CPU: %usage"
        max_threshold = 80
}

memory {
        format = "MEM: %used/%total"
        threshold_degraded = "1G"
        format_degraded = "MEM LOW: %free"
}

disk "/" {
        format = "%avail"
}

load {
        format = "load: %1min"
        max_threshold = "8"
}

tztime local {
        format = "%Y-%m-%d %H:%M:%S"
}
