# Never commit private keys or decrypted auth keys
*.key
*.pem
*.age.dec
auth-key-*[^.age]

# age private key files — NEVER commit
keys.txt
*.age-private

# Decrypted secret plaintext — NEVER commit
secrets/*.dec
secrets/**/*.dec
secrets/*.plain
secrets/**/*.plain

# Node-role override (local machine state)
mesh/config/node-role

# Build artifacts
*.o
*.so
