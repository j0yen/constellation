#!/usr/sbin/nft -f
# /etc/nftables.conf — constellation cloud hub firewall.
# Generated by Ansible (cloud role). Do NOT edit manually.

flush ruleset

table inet filter {
  chain input {
    type filter hook input priority 0; policy drop;

    # Loopback — always allow
    iif lo accept

    # Established / related — allow
    ct state established,related accept

    # ICMPv4 / ICMPv6 — allow ICMP echo
    ip protocol icmp accept
    ip6 nexthdr icmpv6 accept

{% for rule in cloud_open_ports %}
    # {{ rule.comment }}
    tcp dport {{ rule.port }} accept
{% endfor %}

    # Log and drop everything else
    log prefix "[nft-cloud-drop] " flags all
    drop
  }

  chain forward {
    # Allow forwarding for exit-node traffic (Tailscale handles its own filtering)
    type filter hook forward priority 0; policy accept;
  }

  chain output {
    type filter hook output priority 0; policy accept;
  }
}
