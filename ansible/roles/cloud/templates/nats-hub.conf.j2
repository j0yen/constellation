# NATS hub configuration — generated by Ansible (cloud role).
# Primary: JetStream domain "hub", leafnode TLS listener on :{{ nats_leaf_port }}.
# Do NOT edit directly; changes are overwritten on next ansible-playbook run.

server_name: "{{ tailscale_hostname }}"

# Internal client listener (fleet-local, Tailscale-only)
listen: "0.0.0.0:{{ nats_client_port }}"

# HTTP monitoring — loopback only
http: "127.0.0.1:{{ nats_monitor_port }}"

# ---------------------------------------------------------------------------
# JetStream — domain "hub"
# ---------------------------------------------------------------------------
jetstream {
  domain: {{ nats_js_domain }}
  store_dir: "{{ nats_data_dir }}"
  max_file_store: 10Gb
  max_mem_store: 512Mb
}

# ---------------------------------------------------------------------------
# Leafnode listener — TLS, fleet leaves connect here on :{{ nats_leaf_port }}
# ---------------------------------------------------------------------------
leafnodes {
  listen: "0.0.0.0:{{ nats_leaf_port }}"

  tls {
    cert_file: "{{ nats_creds_dir }}/hub-cert.pem"
    key_file:  "{{ nats_creds_dir }}/hub-key.pem"
    # ca_file:   "{{ nats_creds_dir }}/ca.pem"   # uncomment if using custom CA
    timeout:   2
  }
}

# ---------------------------------------------------------------------------
# Authorization (operator / accounts or simple user/password)
# ---------------------------------------------------------------------------
# For the initial roll-out a simple token is sufficient; replace with NKeys
# operator mode once constellation-bus ships its credential manager.
{% if nats_auth_token is defined and nats_auth_token %}
authorization {
  token: "{{ nats_auth_token }}"
}
{% endif %}

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
log_file: "/var/log/nats/hub.log"
logtime: true
debug: false
trace: false
max_traced_msg_len: 1024
