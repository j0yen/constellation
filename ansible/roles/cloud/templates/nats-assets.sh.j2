#!/usr/bin/env bash
# nats-assets.sh — idempotently create WM_WORK stream + WM_NODES KV bucket.
# Generated by Ansible (cloud role). Run after nats-server is up.
set -euo pipefail

NATS_SERVER="nats://127.0.0.1:{{ nats_client_port }}"
{% if nats_auth_token is defined and nats_auth_token %}
CREDS_ARGS=("--creds" "/dev/null" "--token" "{{ nats_auth_token }}")
{% else %}
CREDS_ARGS=()
{% endif %}

nats_cmd() { nats "$@" "${CREDS_ARGS[@]}" --server "$NATS_SERVER"; }

echo "[nats-assets] Ensuring WM_WORK stream..."
if ! nats_cmd stream info WM_WORK &>/dev/null; then
  nats_cmd stream add WM_WORK \
    --subjects "wm.work.>" \
    --retention work \
    --storage file \
    --max-bytes {{ nats_stream_wm_work.max_bytes }} \
    --replicas {{ nats_stream_wm_work.replicas }} \
    --defaults
  echo "[nats-assets] WM_WORK created."
else
  echo "[nats-assets] WM_WORK already exists."
fi

echo "[nats-assets] Ensuring WM_NODES KV bucket..."
if ! nats_cmd kv info WM_NODES &>/dev/null; then
  nats_cmd kv add WM_NODES \
    --ttl {{ nats_kv_wm_nodes.ttl }}s \
    --storage file \
    --replicas {{ nats_kv_wm_nodes.replicas }}
  echo "[nats-assets] WM_NODES created."
else
  echo "[nats-assets] WM_NODES already exists."
fi

echo "[nats-assets] Done."
